{
  "name": "ПСИХОЛОГІЯ СИЛИ",
  "short_name": "ПСИХОЛОГІЯ",
  "description": "PWA додаток для захисту прав водіїв",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#000000",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "uk",
  "categories": ["utilities", "productivity", "business"],
  "permissions": {
    "camera": {
      "description": "Доступ до камери для запису відео під час спілкування з поліцією"
    },
    "microphone": {
      "description": "Доступ до мікрофону для запису аудіо під час спілкування з поліцією"
    },
    "geolocation": {
      "description": "Доступ до геолокації для фіксації місця інциденту"
    }
  },
  "icons": [
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png"
    },
    {
      "src": "icons/apple-touch-icon-180x180.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/home.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Головний екран додатку"
    },
    {
      "src": "screenshots/emergency.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Екстрений режим"
    },
    {
      "src": "screenshots/incidents.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Список інцидентів"
    }
  ],
  "shortcuts": [
    {
      "name": "Екстрений режим",
      "short_name": "SOS",
      "description": "Швидкий доступ до екстреного режиму",
      "url": "/emergency",
      "icons": [
        {
          "src": "icons/sos-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Інциденти",
      "short_name": "Інциденти",
      "description": "Переглянути зафіксовані інциденти",
      "url": "/incidents",
      "icons": [
        {
          "src": "icons/incidents-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Скарги",
      "short_name": "Скарги",
      "description": "Створити скаргу до поліції",
      "url": "/complaints",
      "icons": [
        {
          "src": "icons/complaints-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Штрафи",
      "short_name": "Штрафи",
      "description": "Калькулятор штрафів ПДР",
      "url": "/fines",
      "icons": [
        {
          "src": "icons/fines-96x96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+psychology",
      "url": "/handle-protocol?type=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "video",
          "accept": ["video/*"]
        },
        {
          "name": "image",
          "accept": ["image/*"]
        }
      ],
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
